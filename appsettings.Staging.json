{
  "EnableDetailedLogging": true,
  "RunMigrationsOnStartup": false,
  "Cors": {
    "AllowedOrigins": ["https://sf-management-hmg.vercel.app"]
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore.Authentication": "Information",
      "SFManagement.Infrastructure.Authorization": "Information"
    }
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information"
    },
    "Properties": {
      "Environment": "Staging"
    }
  }
}
